# ── Qualrec Solutions — copy to .env.local and fill in ──────────────────────

# Supabase (Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
# Server only — never expose. Used by Server Actions for trusted writes / storage.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Email — choose ONE provider (see qualrec-build-spec.md §5)
# Option A: Resend (recommended; verify qualrecsol.com on Hostinger DNS)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="Qualrec Solutions <noreply@qualrecsol.com>"
# Option B: Gmail SMTP fallback (works now, no DNS) — set these instead of Resend
# GMAIL_USER=info@qualrecsol.com
# GMAIL_APP_PASSWORD=your-16-char-app-password

# Where form notifications go
NOTIFY_EMAIL_TO=info@qualrecsol.com
CAREERS_EMAIL_TO=career@qualrecsol.com

# Protects the keep-alive cron route
CRON_SECRET=generate-a-long-random-string

# Used for metadata / OG / canonical URLs (temp Vercel URL now, real domain later)
NEXT_PUBLIC_SITE_URL=https://qualrec-solutions.vercel.app
